---
title: AVL Tree  |  Self-balancing BST  —  Height O(log n) guaranteed
---
flowchart TD
    classDef startEnd fill:#22c55e,stroke:#15803d,color:#fff
    classDef decision fill:#f59e0b,stroke:#b45309,color:#fff
    classDef process fill:#3b82f6,stroke:#1d4ed8,color:#fff
    classDef result fill:#8b5cf6,stroke:#6d28d9,color:#fff

    subgraph BALANCE ["Balance Check — runs after every insert / delete"]
        BA([After insert or delete]):::startEnd --> BB["Recompute balanceFactor = height(left) - height(right)"]:::process
        BB --> BC{"balanceFactor == -1, 0, or 1?"}:::decision
        BC -- Yes --> BD([Tree is balanced · done]):::result
        BC -- "balanceFactor > 1 · Left Heavy" --> BE{"Left child's balanceFactor >= 0?"}:::decision
        BE -- "Yes · Left-Left case" --> BF["Right Rotation on current node"]:::process
        BE -- "No · Left-Right case" --> BG["Left Rotation on left child · then Right Rotation on current node"]:::process
        BC -- "balanceFactor < -1 · Right Heavy" --> BH{"Right child's balanceFactor <= 0?"}:::decision
        BH -- "Yes · Right-Right case" --> BI["Left Rotation on current node"]:::process
        BH -- "No · Right-Left case" --> BJ["Right Rotation on right child · then Left Rotation on current node"]:::process
        BF --> BK([Balanced · done]):::result
        BG --> BK
        BI --> BK
        BJ --> BK
    end

    subgraph ROTATIONS ["Rotation Reference"]
        R1["Right Rotation · LL fix\n parent takes left child's position\n left child becomes new root\n left child's right subtree moves to parent's left"]:::process
        R2["Left Rotation · RR fix\n parent takes right child's position\n right child becomes new root\n right child's left subtree moves to parent's right"]:::process
        R3["Left-Right · LR fix\n Left Rotation on left child\n then Right Rotation on parent"]:::process
        R4["Right-Left · RL fix\n Right Rotation on right child\n then Left Rotation on parent"]:::process
    end
