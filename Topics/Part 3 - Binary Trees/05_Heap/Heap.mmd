---
title: Almost Complete Binary Tree & Heap  |  Array representation  —  No pointers needed
---
flowchart TD
    classDef startEnd fill:#22c55e,stroke:#15803d,color:#fff
    classDef decision fill:#f59e0b,stroke:#b45309,color:#fff
    classDef process fill:#3b82f6,stroke:#1d4ed8,color:#fff
    classDef result fill:#8b5cf6,stroke:#6d28d9,color:#fff
    classDef formula fill:#0f172a,stroke:#3b82f6,color:#7dd3fc

    subgraph STRUCTURE ["Almost Complete Binary Tree — filled level by level, left to right"]
        T1["(1)  index 1  ←  root"]:::startEnd
        T1 --> T2["(3)  index 2"]:::process
        T1 --> T3["(6)  index 3"]:::process
        T2 --> T4["(5)  index 4"]:::process
        T2 --> T5["(9)  index 5"]:::process
        T3 --> T6["(8)  index 6"]:::process
        T3 --> T7["empty · next insert goes here  →  index 7"]:::result
    end

    subgraph ARRAY ["Array Mapping  (1-indexed)"]
        ARR["Index:  1    2    3    4    5    6\nValue:  1    3    6    5    9    8"]:::formula
    end

    subgraph FORMULAS ["Index Formulas for node at index i"]
        F1["Parent      →  i / 2"]:::formula
        F2["Left child  →  2 * i"]:::formula
        F3["Right child →  2 * i + 1"]:::formula
        F1 --> EX["Example: node at index 2\n  Parent      = 2/2 = 1 ✓\n  Left child  = 2×2 = 4 ✓\n  Right child = 2×2+1 = 5 ✓"]:::process
    end

    subgraph HEAP_PROPERTY ["Min-Heap Property"]
        HP1([Insert value at next free position]):::startEnd --> HP2["Bubble up: swap with parent while value < parent"]:::process
        HP2 --> HP3{"Heap property satisfied?"}:::decision
        HP3 -- No --> HP2
        HP3 -- Yes --> HP4([Heap is valid · done]):::result
    end
